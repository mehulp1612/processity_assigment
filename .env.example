# Copy to .env and fill in.

# Anthropic API key for the Claude Agent SDK
ANTHROPIC_API_KEY=sk-ant-...

# Vercel AI Gateway (OpenAI-compatible endpoint, one key for many providers).
# Dashboard → AI Gateway → API Keys.
AI_GATEWAY_API_KEY=vck_...

# Telegram bot token from @BotFather (/newbot)
TELEGRAM_BOT_TOKEN=123456:ABC-...

# Model for the agent (optional; defaults set in code)
AGENT_MODEL=poolside/laguna-s-2.1-free

# PostgreSQL. Inside docker compose this is set for you (host "db"); override
# here only when running the app directly on the host.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/store

# Database the test suite creates and wipes. Never point this at the real store.
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/store_test

# poolside direct API (platform.poolside.ai -> API Keys); free developer keys
POOLSIDE_API_KEY=...

# --- Model provider (any OpenAI-compatible endpoint) -------------------------
# poolside (free developer key, no card): https://platform.poolside.ai -> API Keys
MODEL_API_KEY=...
MODEL_BASE_URL=https://inference.poolside.ai/v1
AGENT_MODEL=poolside/laguna-s-2.1
#
# Swap providers by changing the three lines above, e.g.
#   MODEL_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   AGENT_MODEL=gemini-2.5-flash
