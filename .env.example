# Copy to .env and fill in. Never commit .env — it is gitignored and
# .dockerignore'd, so secrets stay off the repo and out of the image.

# --- Telegram ----------------------------------------------------------------
# Token from @BotFather (/newbot). Rotate with /revoke if it ever leaks.
TELEGRAM_BOT_TOKEN=123456:ABC-...

# Public HTTPS URL for the webhook, e.g. https://example.com/telegram/webhook
# Leave UNSET to long-poll instead — that is the default and needs no tunnel.
# TELEGRAM_WEBHOOK_URL=

# --- Model provider ----------------------------------------------------------
# Any OpenAI-compatible endpoint. The agent talks plain HTTP, so switching
# providers is these three lines and a restart — no code change.
#
# poolside (free developer key, no card): https://platform.poolside.ai -> API Keys
MODEL_API_KEY=...
MODEL_BASE_URL=https://inference.poolside.ai/v1
AGENT_MODEL=poolside/laguna-s-2.1
#
# Alternatives, same shape:
#   MODEL_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   AGENT_MODEL=gemini-2.5-flash
#
#   MODEL_BASE_URL=https://api.groq.com/openai/v1
#   AGENT_MODEL=llama-3.3-70b-versatile

# --- PostgreSQL --------------------------------------------------------------
# Under docker compose this is set for you (host "db"); override only when
# running the app directly on the host.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/store

# Database the test suite creates and wipes. Never point this at the real store.
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/store_test

# Required by docker-compose.prod.yml only. Generate with: openssl rand -hex 24
# POSTGRES_PASSWORD=
